{
  "name": "shoo-mock-api",
  "version": "1.0.0",
  "description": "SHOO local mock API server — serves assets/mock JSON over HTTP",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "check": "node scripts/check-routes.js",
    "generate-products": "node scripts/generate-product-mock.js",
    "sync-mock": "node scripts/sync-mock-data.js",
    "mock:refresh": "npm run generate-products && npm run sync-mock"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2"
  }
}
